# OpenAI-compatible model endpoint
OPENAI_API_KEY="your-openai-api-key-or-ollama"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL_TRIAGE="gpt-4.1-mini"
OPENAI_MODEL_DRAFT="gpt-4.1-mini"
OPENAI_AGENTS_DISABLE_TRACING="true"

# Suspicious classification quality gate
SUSPICIOUS_CONFIDENCE_THRESHOLD="0.80"
SUSPICIOUS_MIN_SIGNALS="2"

# Trusted senders (comma-separated; optional)
TRUSTED_SENDER_DOMAINS=""
TRUSTED_SENDER_EMAILS=""

# Gmail OAuth local files
GOOGLE_CREDENTIALS_FILE="credentials.json"
GOOGLE_TOKEN_FILE="token.json"

# Runtime
LOG_LEVEL="INFO"
MAX_EMAILS_PER_RUN="10"
# Process only recent inbox emails; set 0 to disable
MAX_EMAIL_AGE_HOURS="12"
# Backfill/testing mode: include read inbox emails
INCLUDE_READ_INBOX_EMAILS="false"
# Optional subject filter to safely scope backfill runs
INBOX_SUBJECT_CONTAINS=""
# Optional default recipient for scripts/send_stress_test_emails.py
STRESS_TEST_TO_EMAIL=""
# Optional default number of generated stress emails
STRESS_TEST_COUNT="15"

# Labeling behavior
CATEGORY_LABELING_ENABLED="true"
EXCLUDE_ALREADY_LABELED="true"

# Map topic labels to your existing Gmail labels
LABEL_PERSONAL_DIRECT="Personal & Direct"
LABEL_FINANCE="Finance"
LABEL_SALES_OUTREACH="Sales & Outreach"
LABEL_EVENTS_CALENDAR="Events & Calendar"
LABEL_NEWSLETTERS="Newsletters"
LABEL_SECURITY_ADMIN="Security & Admin"
LABEL_PROFESSIONAL_NETWORK="Professional Network"
LABEL_RECEIPTS_BILLING="Receipts & Billing"
LABEL_SAAS_TOOLS="SaaS & Tools"

# Overlay label applied when action is REPLY
LABEL_ACTION_REQUIRED="Action Required"
